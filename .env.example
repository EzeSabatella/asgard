# Asgard Environment Variables

# OpenAI Configuration (requerido si embedding provider=openai)
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek Configuration (requerido si llm provider=deepseek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# SQLCipher Configuration
SQLCIPHER_KEY=your_secret_encryption_key_here

# Embedding Configuration
# EMBEDDING_PROVIDER: openai | ollama
EMBEDDING_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB Configuration
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# General
DEBUG=true
DATABASE_PATH=./data/storage
